{
  "name": "dashboard-admin",
  "version": "1.20.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "validate:learning": "node --no-warnings --experimental-strip-types scripts/validate-learning.mjs",
    "prebuild": "npm run validate:learning && node scripts/data/ensure-data.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --pretty false",
    "test:admin-pokemon": "node --test scripts/test-admin-pokemon-refactor.mjs",
    "test:learning-flow": "node scripts/test-learning-flow.mjs",
    "check": "npm run lint && npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.26",
    "gsap": "^3.15.0",
    "lucide-react": "^0.561.0",
    "mongodb": "^7.3.0",
    "next": "latest",
    "next-themes": "^0.4.6",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "^3.5.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "latest",
    "playwright": "^1.61.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
