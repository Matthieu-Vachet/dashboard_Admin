# Login local du dashboard personnel
ADMIN_EMAIL=matthieu@example.com
ADMIN_PASSWORD=change-moi
SESSION_SECRET=change-moi-en-production

# Base personnelle du dashboard
# Par défaut le dashboard peut réutiliser MONGODB_URI, mais il écrit dans cette base séparée.
MONGODB_URI=
DASHBOARD_MONGODB_URI=
DASHBOARD_MONGODB_DB=matweb-dashboard-admin

# Statistiques Pokémon GO API
POKEMON_API_URL=https://pokemon-go-7r5q2j05a-matthieu-vachets-projects.vercel.app/api/checklist-v3
POKEMON_API_PUBLIC_URL=https://pokemon-go-api.vercel.app
# Optionnel : même valeur que API_ADMIN_SECRET dans le projet PokemonGo-API.
# Requis seulement si le dashboard appelle une route privée PokemonGo-API.
POKEMON_API_ADMIN_SECRET=

# Admin Pokémon GO
POKEMON_GO_DATA_DIR=../PokemonGo-Data
POKEMON_GO_DATA_REPO=https://github.com/Matthieu-Vachet/PokemonGo-Data.git
POKEMON_GO_DATA_REF=main
# Obligatoire sur Vercel si le repo PokemonGo-Data est privé
POKEMON_GO_DATA_TOKEN=
